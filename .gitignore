# FiveM Server GitIgnore
# ----------------------

# Ephemeral data
cache/
logs/
crashes/
db/
*.log
*.key
server-monitor-token.key

# OS files
.DS_Store
Thumbs.db

# Binaries/Artifacts
FXServer.exe
*.dll
*.pdb
*.so
*.map
citizen/

# Temporary files
server_log.txt
analyze_stats.ps1
import_db.bat
deep_cleanup.ps1

# Large Asset Folders (Escaped brackets for FiveM Compatibility)
resources/\[cars\]/
resources/\[Cars2\]/
resources/\[Map\]/
resources/\[EUP\]/

# Node modules
node_modules/